# Production server
NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# Local Matting Engine
MYML_MATTING_BASE_URL=http://127.0.0.1:8000

# Optional persistent data directory. Leave commented to use ./library.
# LIBRARY_DIR=/data/myml/library

# Auth
MYML_AUTH_SECRET=please_change_this
MYML_COOKIE_SECURE=false

# Users database and initial admin seed
# PostgreSQL is the primary database for users/auth.
# Use either DATABASE_URL or the PG* variables below. Do not commit real passwords.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=myml_user
# PGPASSWORD=change_this_outside_git
# PGDATABASE=myml_canvas
# PGSSL=false
# PGSSL_REJECT_UNAUTHORIZED=true
# Keep certificate verification enabled in production. Set PGSSL_REJECT_UNAUTHORIZED=false only for self-signed certificates or local testing.
#
# Docker-style PostgreSQL aliases are also accepted:
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=myml_user
# POSTGRES_PASSWORD=change_this_outside_git
# POSTGRES_DB=myml_canvas

# Deprecated local-only SQLite fallback from earlier builds. Do not use for cloud deployments.
# MYML_DB_PATH=library/database/myml.db
MYML_SEED_ADMIN_USERNAME=myml
MYML_SEED_ADMIN_PASSWORD=change_this_before_first_start
MYML_SEED_INTERNAL_USERS=false
# Required only when MYML_SEED_INTERNAL_USERS=true. Do not commit real passwords.
MYML_GROUP1_USERNAME=
MYML_GROUP1_PASSWORD=
MYML_GROUP2_USERNAME=
MYML_GROUP2_PASSWORD=

# Deprecated first-phase single-account auth. Do not use for login in phase 2.
# MYML_ADMIN_USERNAME=
# MYML_ADMIN_PASSWORD=

# Model providers
GEMINI_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
HAILUO_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=

# APIMart default AI provider
APIMART_BASE_URL=
APIMART_API_KEY=
APIMART_TEXT_MODEL=
APIMART_IMAGE_MODEL=
APIMART_IMAGE_FALLBACK_MODEL=
APIMART_IMAGE_RESOLUTION=
APIMART_IMAGE_SIZE=
APIMART_IMAGE_POLL_INTERVAL_MS=
APIMART_IMAGE_POLL_TIMEOUT_MS=

# Background generation task worker. Keep disabled unless you want queued tasks to submit paid provider jobs.
TASK_WORKER_ENABLED=false

# Legacy custom model API fallback
CUSTOM_API_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_NANO_BANANA_BASE_URL=
CUSTOM_NANO_BANANA_API_KEY=
CUSTOM_NANO_BANANA_MODEL=
CUSTOM_SEEDANCE_BASE_URL=
CUSTOM_SEEDANCE_API_KEY=
CUSTOM_SEEDANCE_MODEL=
CUSTOM_SEEDANCE_PUBLIC_BASE_URL=
PUBLIC_BASE_URL=
SERVER_PUBLIC_URL=

# Chat agent
CHAT_API_KEY=
CHAT_API_BASE_URL=
CHAT_MODEL=
CHAT_REASONING_EFFORT=
CHAT_TOPIC_MODEL=

# Social integrations
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_CALLBACK_URL=

# Local model discovery
LOCAL_MODELS_DIR=
